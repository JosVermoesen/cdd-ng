<!-- ====== TRANSACTION — OGM ====== -->
<CdtTrfTxInf>
    <PmtId>
        <InstrId>{serialNumber}</InstrId>
        <EndToEndId>{endToEndId}</EndToEndId>
    </PmtId>

    <Amt>
        <InstdAmt Ccy="EUR">{amount}</InstdAmt>
    </Amt>

    <!-- <CdtrAgt>
        <FinInstnId>
            <BIC>{creditorBIC}</BIC>
        </FinInstnId>
    </CdtrAgt> -->

    <Cdtr>
        <Nm>{creditorName}</Nm>
    </Cdtr>
    <CdtrAcct>
        <Id>
            <IBAN>{creditorIBAN}</IBAN>
        </Id>
    </CdtrAcct>

    <!-- Example Structured Message (OGM) -->
    <RmtInf>
        <Strd>
            <CdtrRefInf>
                <Tp>
                    <CdOrPrtry>
                        <Cd>SCOR</Cd>
                    </CdOrPrtry>
                    <Issr>BBA</Issr>
                </Tp>
                <Ref>{ogmReference}</Ref>
            </CdtrRefInf>
        </Strd>
    </RmtInf>
</CdtTrfTxInf>